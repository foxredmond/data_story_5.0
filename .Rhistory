df2 <- df2 %>% rename(pong = "Who would win in a game of ping pong: Chris Van de Ven or Eric Ezell?",
hamilton = "Who knows more Hamilton lyrics: Lily Thompson or Eric Ezell?",
frisbee = "Who can throw a frisbee farther: John Benson or Eric Ezell?",
money35 = "What do you expect your annual income to be when you are 35?") %>%
filter(`Your gender:` != "attack helicopter")
frisbee <- gsub("!", " Benson", df2$frisbee)
frisbee <- gsub("Probably John Benson, sorry Dr. Ezell", "John Benson", frisbee)
frisbee <- gsub("JOhn Benson", "John Benson", frisbee)
frisbee <- gsub("benson", "Benson", frisbee)
frisbee <- gsub("Probably Eric", "Eric Ezell", frisbee)
df2$frisbee <- frisbee
df2 <- df2 %>% mutate(frisbee = ifelse(frisbee == "Benson", "John Benson", frisbee))
`Your gender:` <- gsub("MAN", "Male", df2$`Your gender:`)
`Your gender:` <- gsub("woman", "Female",`Your gender:`)
`Your gender:` <- gsub("female", "Female",`Your gender:`)
`Your gender:` <- gsub("attack helicopter", "Attack Helicopter",`Your gender:`)
df2$`Your gender:` <- `Your gender:`
df2 %>% select(`Your gender:`, frisbee) %>% kable
money35 <- gsub("k", "000", df2$money35)
money35 <- gsub("\\$", "", money35)
money35 <- gsub("dollars", "", money35)
money35 <- gsub(",", "", money35)
df2$money35 <- money35 %>% as.numeric
ggplot(df2,
aes(x= `Your age:`,
y= money35,
)) +
geom_point() +
scale_y_continuous(trans = "log")
